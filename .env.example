PORT=3000
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=1800000
SESSION_TTL_SECONDS=3600

# Optional fallback when requests do not include Authorization.
# Examples: "Bearer username:password" or "Basic <base64(username:password)>"
OPENWEBUI_PROXY_AUTHORIZATION=

OPENWEBUI_BASE_URL=http://localhost:8080
OPENWEBUI_LOGIN_PATH=/api/v1/auths/ldap
OPENWEBUI_LOGIN_USERNAME_FIELD=user
OPENWEBUI_LOGIN_PASSWORD_FIELD=password
OPENWEBUI_MODELS_PATH=/api/models
OPENWEBUI_CHAT_COMPLETIONS_PATH=/api/chat/completions

# Optional JSON fragments merged into upstream payloads.
# Example: {"remember":true}
OPENWEBUI_LOGIN_EXTRA_JSON=
OPENWEBUI_CHAT_EXTRA_JSON=
